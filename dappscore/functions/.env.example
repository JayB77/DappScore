# ── DappScore API — VPS Environment Variables ──────────────────────────────────
# Copy to .env and fill in real values.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# CORS — comma-separated origins, or * for all (not recommended in production)
# CORS_ORIGIN=https://app.dappscore.xyz

# ── PostgreSQL (required) ─────────────────────────────────────────────────────
# Example (Hetzner / DigitalOcean / self-hosted):
DATABASE_URL=postgresql://dappscore:yourpassword@localhost:5432/dappscore

# ── Redis (optional, strongly recommended) ───────────────────────────────────
# If not set, the API falls back to PostgreSQL stats_cache table.
REDIS_URL=redis://localhost:6379

# ── Auth Keys ─────────────────────────────────────────────────────────────────
# Admin endpoints (GET /api/v1/admin/*)
ADMIN_API_KEY=

# Claim allocation endpoints (GET/PUT/DELETE /api/v1/claim/*)
CLAIM_ADMIN_KEY=

# Airdrop allocation endpoints (GET/PUT/DELETE /api/v1/airdrop/*)
AIRDROP_ADMIN_KEY=

# ── The Graph Subgraph ────────────────────────────────────────────────────────
SUBGRAPH_URL=https://api.thegraph.com/subgraphs/name/your-org/dappscore

# Shared secret for incoming subgraph webhook pushes (Goldsky / Notifi)
SUBGRAPH_WEBHOOK_SECRET=

# ── Alchemy ───────────────────────────────────────────────────────────────────
ALCHEMY_API_KEY=
# HMAC signing key for verifying incoming Alchemy address-activity webhooks
ALCHEMY_SIGNING_KEY=

# ── Moralis ───────────────────────────────────────────────────────────────────
MORALIS_API_KEY=

# ── GoPlus Security ───────────────────────────────────────────────────────────
# Optional — GoPlus has a free tier; leave blank to use it unauthenticated
# GOPLUS_API_KEY=

# ── Block Explorers ───────────────────────────────────────────────────────────
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
ARBISCAN_API_KEY=
POLYGONSCAN_API_KEY=
BSCSCAN_API_KEY=
OPTIMISM_API_KEY=
SNOWTRACE_API_KEY=

# ── Sale keys (comma-separated, for legacy SALE_API_KEYS check) ───────────────
# SALE_API_KEYS=key1,key2
