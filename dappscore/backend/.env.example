# DappScore Backend Configuration

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Blockchain RPC
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# The Graph Subgraph
SUBGRAPH_URL=http://localhost:8000/subgraphs/name/dappscore

# Telegram Bot (for alerts)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Email alerts via Resend (https://resend.com — free tier: 3k emails/month)
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=alerts@dappscore.io

# Database (required — run functions/migrations/001_initial.sql on first setup)
DATABASE_URL=postgresql://user:password@localhost:5432/dappscore

# Admin API key (required for /api/v1/admin routes)
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=your_admin_api_key

# Optional: Redis for caching
# REDIS_URL=redis://localhost:6379

# Optional: External APIs
# ETHERSCAN_API_KEY=your_api_key
# BASESCAN_API_KEY=your_api_key
# COINGECKO_API_KEY=your_api_key
