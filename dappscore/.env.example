# ============================================================
# DappScore — Master Environment Variables
# Copy to .env.local (Next.js) and fill in your values.
#
# Firebase Functions vars are set separately:
#   firebase functions:secrets:set KEY_NAME
# ============================================================


# ── Frontend (Next.js) ───────────────────────────────────────────────────────

# WalletConnect — required for wallet connections
# https://cloud.walletconnect.com → Create Project
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Premium listing price in USDC (whole dollars). Default: $100
NEXT_PUBLIC_PREMIUM_LISTING_PRICE=100

# Moralis — client-side multi-chain token data
# https://admin.moralis.io → API Keys
# IMPORTANT: restrict to your domain → Moralis dashboard → Allowed Origins
NEXT_PUBLIC_MORALIS_API_KEY=


# ── Firebase Functions ────────────────────────────────────────────────────────

# The Graph subgraph endpoint
SUBGRAPH_URL=https://api.thegraph.com/subgraphs/name/dappscore/dappscore

# Admin API key — protects /api/v1/admin/* routes
# firebase functions:secrets:set ADMIN_API_KEY
ADMIN_API_KEY=

# Per-project sale API keys — JSON { "<projectId>": "<key>" }
# firebase functions:secrets:set SALE_API_KEYS
SALE_API_KEYS={}

# Moralis — server-side key (same dashboard, no domain restriction needed)
MORALIS_API_KEY=


# ── Alchemy — one key per network app ────────────────────────────────────────
# Alchemy issues a separate API key per app/network.
# https://dashboard.alchemy.com → Create App → select network
#
# ALCHEMY_API_KEY is the generic fallback used for any network
# that doesn't have its own dedicated key below.
# You can start with just the fallback and add per-network keys
# as you create dedicated Alchemy apps (better rate limits + analytics).

ALCHEMY_API_KEY=                   # Generic fallback

# EVM L1s
ALCHEMY_API_KEY_MAINNET=           # Ethereum mainnet
ALCHEMY_API_KEY_BSC=               # BNB Smart Chain
ALCHEMY_API_KEY_AVALANCHE=         # Avalanche C-Chain
ALCHEMY_API_KEY_CELO=              # Celo

# Ethereum L2s / rollups
ALCHEMY_API_KEY_ARBITRUM=          # Arbitrum One
ALCHEMY_API_KEY_OPTIMISM=          # Optimism
ALCHEMY_API_KEY_BASE=              # Base
ALCHEMY_API_KEY_ZKSYNC=            # zkSync Era
ALCHEMY_API_KEY_LINEA=             # Linea
ALCHEMY_API_KEY_SCROLL=            # Scroll
ALCHEMY_API_KEY_POLYGON=           # Polygon PoS
ALCHEMY_API_KEY_POLYGON_ZKEVM=     # Polygon zkEVM
ALCHEMY_API_KEY_ZORA=              # Zora Network
ALCHEMY_API_KEY_UNICHAIN=          # Unichain (Uniswap's L2)
ALCHEMY_API_KEY_MANTLE=            # Mantle
ALCHEMY_API_KEY_BERACHAIN=         # Berachain
ALCHEMY_API_KEY_OPBNB=             # opBNB (BNB Chain L2)

# EVM L1s added March 2026
ALCHEMY_API_KEY_RONIN=             # Ronin (Sky Mavis / Axie Infinity)
ALCHEMY_API_KEY_SEI=               # SEI Network
ALCHEMY_API_KEY_ZETACHAIN=         # ZetaChain

# Newer EVM (mainnet live)
ALCHEMY_API_KEY_MONAD=             # Monad mainnet
ALCHEMY_API_KEY_HYPEREVM=          # HyperEVM (Hyperliquid) — Alchemy subdomain: hyperliquid

# Non-EVM (chain-specific RPC formats)
ALCHEMY_API_KEY_STARKNET=          # Starknet — path: /starknet/version/rpc/v0_9/{key}
ALCHEMY_API_KEY_SOLANA=            # Solana (use alongside HELIUS_API_KEY)


# ── Helius — Solana RPC + DAS API ────────────────────────────────────────────
# Best-in-class Solana data: mint/freeze authority, token metadata, NFTs.
# Required for Solana scam detection.
# https://dev.helius.xyz → Create API Key
HELIUS_API_KEY=


# ── Block Explorer API Keys ───────────────────────────────────────────────────
# Used by scam detection to check contract verification and source code.
# All are optional — missing keys = fewer scam signals, not broken.
# Most offer a free tier sufficient for DappScore's usage.
#
# Chains using public Blockscout (no key needed):
#   Zora, Unichain, ZetaChain, HyperEVM, Monad, SEI

# Ethereum  https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# BNB Chain  https://bscscan.com/myapikey
BSCSCAN_API_KEY=

# opBNB  https://opbnb.bscscan.com/myapikey  (same BscScan account)
OPBNBSCAN_API_KEY=

# Polygon PoS + zkEVM  https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# Arbitrum  https://arbiscan.io/myapikey
ARBISCAN_API_KEY=

# Optimism  https://optimistic.etherscan.io/myapikey
OPTIMISM_ETHERSCAN_API_KEY=

# Base  https://basescan.org/myapikey
BASESCAN_API_KEY=

# Avalanche  https://routescan.io  (Snowtrace replacement — free)
AVALANCHE_API_KEY=

# Fantom  https://ftmscan.com/myapikey
FTMSCAN_API_KEY=

# Celo  https://celoscan.io/myapikey
CELOSCAN_API_KEY=

# Linea  https://lineascan.build/myapikey
LINEASCAN_API_KEY=

# Scroll  https://scrollscan.com/myapikey
SCROLLSCAN_API_KEY=

# Mantle  https://mantlescan.xyz/myapikey
MANTLESCAN_API_KEY=

# Berachain  https://berascan.com/myapikey
BERASCAN_API_KEY=

# Ronin  https://developers.skymavis.com → API Keys
RONIN_EXPLORER_API_KEY=

# Starknet  https://starkscan.co  (optional — increases rate limits)
STARKSCAN_API_KEY=


# ── Native RPC overrides ──────────────────────────────────────────────────────
# Override the default public node for chains not on Alchemy/Moralis.
# Leave blank to use the built-in public endpoint.

RPC_URL_HYPEREVM=                  # default: https://rpc.hyperliquid.xyz/evm
RPC_URL_MONAD=                     # default: https://testnet-rpc.monad.xyz


# ── Backend Express server (backend/ directory) ───────────────────────────────
# Only needed when running the standalone Express backend.

PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# REDIS_URL=redis://localhost:6379


# ── Telegram Bot (telegram-bot/ directory) ───────────────────────────────────
TELEGRAM_BOT_TOKEN=


# ── GoPlus Security API ───────────────────────────────────────────────────────
# Free public tier: ~50 req/min (no token needed).
# Set this to get higher rate limits via bearer auth.
# https://docs.gopluslabs.io/reference/token-security-api
GOPLUS_API_TOKEN=


# ── Optional: CoinGecko (price data) ─────────────────────────────────────────
# https://www.coingecko.com/en/api/pricing  — free tier sufficient
COINGECKO_API_KEY=
