{
  "name": "dappscore-subgraph",
  "version": "1.0.0",
  "description": "The Graph subgraph for DappScore contract indexing",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "deploy": "graph deploy --node https://api.studio.thegraph.com/deploy/ dappscore-subgraph",
    "create-local": "graph create --node http://localhost:8020/ dappscore-subgraph",
    "remove-local": "graph remove --node http://localhost:8020/ dappscore-subgraph",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 dappscore-subgraph"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "0.60.0",
    "@graphprotocol/graph-ts": "0.31.0"
  }
}
