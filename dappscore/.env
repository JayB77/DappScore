# ── Alchemy — one key per network app ────────────────────────────────────────
# Alchemy issues a separate API key per app/network.
# https://dashboard.alchemy.com → Create App → select network
#
# ALCHEMY_API_KEY is the generic fallback used for any network
# that doesn't have its own dedicated key below.
# You can start with just the fallback and add per-network keys
# as you create dedicated Alchemy apps (better rate limits + analytics).

ALCHEMY_API_KEY=eu4fg53KRs9jneLNPjxcd                   # Generic fallback

# EVM L1s
ALCHEMY_API_KEY_MAINNET=https://eth-sepolia.g.alchemy.com/v2/eu4fg53KRs9jneLNPjxcd           # Ethereum mainnet
ALCHEMY_API_KEY_BSC=https://bnb-testnet.g.alchemy.com/v2/eu4fg53KRs9jneLNPjxcd               # BNB Smart Chain
ALCHEMY_API_KEY_AVALANCHE=https://avax-fuji.g.alchemy.com/v2/eu4fg53KRs9jneLNPjxcd         # Avalanche C-Chain
ALCHEMY_API_KEY_CELO=https://celo-sepolia.g.alchemy.com/v2/eu4fg53KRs9jneLNPjxcd              # Celo

