# ============================================================
# DappScore — Master Environment Variables
# Copy to .env.local (Next.js) and fill in your values.
#
# Firebase Functions vars are set separately:
#   firebase functions:secrets:set KEY_NAME
# ============================================================


# ── Frontend (Next.js) ──────────────────────────────────────────────────────

