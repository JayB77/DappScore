# EVM L1s added March 2026
ALCHEMY_API_KEY_RONIN=https://ronin-saigon.g.alchemy.com/v2/eu4fg53KRs9jneLNPjxcd             # Ronin (Sky Mavis / Axie Infinity)
ALCHEMY_API_KEY_SEI=https://sei-testnet.g.alchemy.com/v2/eu4fg53KRs9jneLNPjxcd               # SEI Network
