# DappScore Contract Deployment Configuration
# Copy this file to .env and fill in the values

# Deployer private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Treasury address (receives fees, tokens for distribution)
TREASURY_ADDRESS=0xYourTreasuryAddress

# Base Sepolia USDC (official Circle testnet USDC)
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# USDT address (use USDC address if no USDT available on testnet)
USDT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# NFT metadata base URI (IPFS or HTTPS)
NFT_BASE_URI=https://dappscore.io/nft/

# BaseScan API key for contract verification
BASESCAN_API_KEY=your_basescan_api_key

# ============================================
# After deployment, fill these in for Setup.s.sol
# ============================================

# Deployed contract addresses (fill after running Deploy.s.sol)
SCORE_TOKEN=
TOKEN_SALE=
PROJECT_REGISTRY=
VOTING_ENGINE=
PREMIUM_LISTINGS=
CURATOR_NFT=
